# 仅提供本地开发示例，不要在真实环境中复用这些密码。
POSTGRES_PORT=5432
POSTGRES_DB=mixagent
POSTGRES_USER=mixagent
POSTGRES_PASSWORD=mixagent_dev

REDIS_PORT=6379
REDIS_PASSWORD=mixagent_dev

# Spring Boot 可以使用下列变量覆盖默认连接信息。
DB_URL=jdbc:postgresql://localhost:5432/mixagent
DB_USERNAME=mixagent
DB_PASSWORD=mixagent_dev
REDIS_HOST=localhost

# 阿里云百炼：工作空间地址不包含 Markdown 星号，密钥只保存在本机环境变量中。
MIXAGENT_AI_BASE_URL=https://your-workspace-id.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=replace-with-your-local-secret
MIXAGENT_EMBEDDING_MODEL=text-embedding-v4
MIXAGENT_EMBEDDING_DIMENSIONS=1024

# 知识库管理接口使用 HTTP Basic，开发环境也不要提交真实密码。
MIXAGENT_ADMIN_USERNAME=admin
MIXAGENT_ADMIN_PASSWORD=replace-with-a-strong-local-password
MIXAGENT_KNOWLEDGE_STORAGE_PATH=../MixAgentData/knowledge
